# StateSight baseline environment

API_PORT=8080
WEB_PORT=5173
DATABASE_URL=postgres://postgres:postgres@localhost:5432/statesight?sslmode=disable
REDIS_URL=redis://localhost:6379/0
GITHUB_WEBHOOK_SECRET=replace-me
LOG_LEVEL=info
GIT_BIN=git
GIT_CACHE_DIR=.statesight/git-cache
KUBECTL_BIN=kubectl
AUTH_REQUIRED=false
